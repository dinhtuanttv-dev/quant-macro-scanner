generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MacroNewsRecord {
  id              String   @id @default(cuid())
  headline        String
  summary         String?
  url             String
  type            String
  scope           String
  sourceId        String
  sourceName      String
  rawImpact       Float
  severity        String
  affectedSectors String[]
  relatedTickers  String[]
  contentHash     String   @unique
  publishedAt     DateTime
  fetchedAt       DateTime @default(now())

  @@index([scope])
  @@index([severity])
  @@index([publishedAt])
  @@index([sourceId])
}

enum CatalystCategory {
  earnings
  ma
  regulatory
  rating
  contract
  insider
  macro
}

enum CatalystCredibility {
  confirmed
  rumor
}

enum PropagationDistance {
  direct
  upstream
  downstream
  competitor
  commodity
}

enum ImpactDirection {
  benefit
  harm
}

enum TargetType {
  sector
  ticker
}

enum Horizon {
  short
  medium
  long
}

model CatalystSource {
  id                 String              @id @default(cuid())
  title              String
  category           CatalystCategory
  sourceCredibility  CatalystCredibility
  publishedDate      DateTime
  executionDate      DateTime?
  firstDetectedAt    DateTime            @default(now())
  corroborationCount Int                 @default(1)
  originRecordId     String?             @unique
  edges              ImpactEdge[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([firstDetectedAt])
  @@index([category])
}

model ImpactEdge {
  id                  String              @id @default(cuid())
  sourceId            String
  source              CatalystSource      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  targetType          TargetType
  targetId            String
  direction           ImpactDirection
  propagationDistance PropagationDistance
  hopCount            Int                 @default(1)
  baseWeight          Float
  decayRate           Float
  horizon             Horizon
  createdAt           DateTime            @default(now())

  @@index([targetType, targetId])
  @@index([sourceId])
}